{
  "extends": "@wbc/config/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": true,
    "paths": {
      "@wbc/db": ["../../packages/db/src"],
      "@wbc/shared": ["../../packages/shared/src"],
      "@wbc/shared/*": ["../../packages/shared/src/*"],
      "@wbc/validators": ["../../packages/validators/src"],
      "@wbc/i18n": ["../../packages/i18n/src"]
    }
  },
  "include": ["src/**/*", "../../packages/business/**/*.ts"]
}
