{
  "extends": "@wbc/config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "declaration": false,
    "declarationMap": false,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@wbc/db": ["../../packages/db/src"],
      "@wbc/shared": ["../../packages/shared/src"],
      "@wbc/shared/*": ["../../packages/shared/src/*"],
      "@wbc/validators": ["../../packages/validators/src"],
      "@wbc/i18n": ["../../packages/i18n/src"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*", ".next/types/**/*.ts", "../../packages/business/**/*.ts"],
  "exclude": ["node_modules"]
}
